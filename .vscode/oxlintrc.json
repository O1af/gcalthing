{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "import"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "warn",
    "react/react-in-jsx-scope": "off"
  },
  "settings": {
    "react": {
      "runtime": "automatic"
    },
    "jsx": {
      "runtime": "automatic"
    }
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "**/routeTree.gen.ts",
    ".wrangler/"
  ]
}
